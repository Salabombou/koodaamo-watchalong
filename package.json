{
  "name": "koodaamo-watchalong",
  "productName": "koodaamo-watchalong",
  "version": "1.3.1",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Salabombou/koodaamo-watchalong.git"
  },
  "description": "An Electron app for synchronizing video playback with friends.",
  "main": ".webpack/main",
  "private": true,
  "scripts": {
    "dev": "electron-forge start",
    "dev:2": "electron . --user-data-dir=./.tmp/client2",
    "lint": "eslint .",
    "check-types": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "clean": "rimraf dist release",
    "build": "pnpm run build:main && pnpm run build:renderer",
    "build:main": "cross-env TS_NODE_PROJECT=tsconfig.build.json webpack --config webpack.build.main.ts",
    "build:renderer": "cross-env TS_NODE_PROJECT=tsconfig.build.json webpack --config webpack.build.renderer.ts",
    "dist": "pnpm run clean && pnpm run build && electron-builder"
  },
  "build": {
    "appId": "com.salabombou.koodaamo-watchalong",
    "productName": "koodaamo-watchalong",
    "compression": "maximum",
    "afterPack": "./scripts/afterPackPrune.js",
    "electronLanguages": [
      "en-US"
    ],
    "directories": {
      "output": "release"
    },
    "files": [
      "package.json",
      ".webpack/**/*"
    ],
    "extraResources": [],
    "win": {
      "target": [
        "nsis"
      ],
      "extraResources": [
        {
          "from": "resources/bin/win32/${arch}/ffprobe.exe",
          "to": "ffprobe.exe"
        },
        {
          "from": "resources/bin/win32/${arch}/ffmpeg.exe",
          "to": "ffmpeg.exe"
        }
      ]
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "extraResources": [
        {
          "from": "resources/bin/darwin/${arch}/ffprobe",
          "to": "ffprobe"
        },
        {
          "from": "resources/bin/darwin/${arch}/ffmpeg",
          "to": "ffmpeg"
        }
      ]
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "extraResources": [
        {
          "from": "resources/bin/linux/${arch}/ffprobe",
          "to": "ffprobe"
        },
        {
          "from": "resources/bin/linux/${arch}/ffmpeg",
          "to": "ffmpeg"
        }
      ]
    },
    "publish": [
      {
        "provider": "github",
        "owner": "Salabombou",
        "repo": "koodaamo-watchalong"
      }
    ]
  },
  "keywords": [
    "electron",
    "watchalong",
    "video",
    "sync"
  ],
  "author": {
    "name": "Salabombou",
    "email": "salabombo@outlook.com"
  },
  "license": "MIT",
  "pnpm": {
    "onlyBuiltDependencies": [
      "bufferutil",
      "electron",
      "electron-winstaller",
      "utf-8-validate"
    ]
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.11.1",
    "@electron-forge/plugin-auto-unpack-natives": "^7.11.1",
    "@electron-forge/plugin-webpack": "^7.11.1",
    "@electron-forge/shared-types": "^7.11.1",
    "@eslint/css": "^0.14.1",
    "@eslint/js": "^9.39.4",
    "@eslint/json": "^1.1.0",
    "@eslint/markdown": "^7.5.1",
    "@tailwindcss/postcss": "^4.2.1",
    "@types/electron-squirrel-startup": "^1.0.2",
    "@types/fs-extra": "^11.0.4",
    "@types/localtunnel": "^2.0.4",
    "@types/node": "^25.5.0",
    "@types/range-parser": "^1.2.7",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vercel/webpack-asset-relocator-loader": "^1.10.0",
    "autoprefixer": "^10.4.27",
    "cross-env": "^10.1.0",
    "css-loader": "^7.1.4",
    "daisyui": "^5.5.19",
    "electron": "40.1.0",
    "electron-builder": "^26.8.1",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "fork-ts-checker-webpack-plugin": "^9.1.0",
    "globals": "^17.4.0",
    "html-webpack-plugin": "^5.6.6",
    "node-loader": "^2.1.0",
    "postcss": "^8.5.8",
    "postcss-loader": "^8.2.1",
    "prettier": "3.8.1",
    "rimraf": "^6.1.3",
    "style-loader": "^4.0.0",
    "tailwindcss": "^4.2.1",
    "ts-loader": "^9.5.4",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.0",
    "webpack": "^5.105.4",
    "webpack-cli": "^6.0.1"
  },
  "dependencies": {
    "@fontsource/space-grotesk": "^5.2.10",
    "@fortawesome/fontawesome-free": "^7.2.0",
    "electron-is-dev": "^3.0.1",
    "electron-squirrel-startup": "^1.0.1",
    "electron-updater": "^6.8.3",
    "fs-extra": "^11.3.4",
    "hls.js": "^1.6.15",
    "localtunnel": "^2.0.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.13.1",
    "terser-webpack-plugin": "^5.4.0",
    "untun": "^0.1.3",
    "uuid": "^13.0.0",
    "winston": "^3.19.0"
  }
}
